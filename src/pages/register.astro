---
import BaseLayout from '../layouts/BaseLayout.astro';

const user = Astro.locals.user;
if (user) return Astro.redirect(user.role === 'student' ? '/student/dashboard' : '/parent/dashboard');
---

<BaseLayout title="Register">
  <div style="max-width: 440px; margin: 2rem auto;">
    <div class="page-header">
      <h1>Create Account</h1>
      <p>Sign up as a student or parent.</p>
    </div>

    <div id="error-msg" class="alert alert-error" style="display:none"></div>

    <form id="register-form" class="card">
      <div class="form-group">
        <label for="name">Full Name</label>
        <input type="text" id="name" name="name" required />
      </div>
      <div class="form-group">
        <label for="email">Email</label>
        <input type="email" id="email" name="email" required />
      </div>
      <div class="form-group">
        <label for="password">Password</label>
        <input type="password" id="password" name="password" required minlength="8" />
        <small style="color: var(--color-text-muted);">Minimum 8 characters</small>
      </div>
      <div class="form-group">
        <label>I am a...</label>
        <div class="radio-group">
          <label>
            <input type="radio" name="role" value="student" checked /> Student
          </label>
          <label>
            <input type="radio" name="role" value="parent" /> Parent
          </label>
        </div>
      </div>
      <div class="form-group" id="invite-group" style="display:none">
        <label for="invite_code">Student Invite Code</label>
        <input type="text" id="invite_code" name="invite_code" placeholder="e.g. A1B2C3D4" />
        <small style="color: var(--color-text-muted);">Ask your student for their invite code.</small>
      </div>
      <button type="submit" class="btn btn-primary" style="width:100%">Create Account</button>
    </form>

    <p style="text-align:center; margin-top:1rem; font-size:0.9rem;">
      Already have an account? <a href="/login">Login</a>
    </p>
  </div>
</BaseLayout>

<script>
  const form = document.getElementById('register-form') as HTMLFormElement;
  const errorMsg = document.getElementById('error-msg')!;
  const inviteGroup = document.getElementById('invite-group')!;
  const roleRadios = form.querySelectorAll<HTMLInputElement>('input[name="role"]');

  roleRadios.forEach((radio) => {
    radio.addEventListener('change', () => {
      inviteGroup.style.display = radio.value === 'parent' && radio.checked ? 'block' : 'none';
    });
  });

  form.addEventListener('submit', async (e) => {
    e.preventDefault();
    errorMsg.style.display = 'none';

    const formData = new FormData(form);
    const res = await fetch('/api/auth/register', { method: 'POST', body: formData });

    if (res.redirected) {
      window.location.href = res.url;
      return;
    }

    const data = await res.json();
    errorMsg.textContent = data.error || 'Registration failed.';
    errorMsg.style.display = 'block';
  });
</script>
